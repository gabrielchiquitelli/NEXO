rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.cargo == "admin";
    }

    function hasVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function hasVerifiedPhone() {
      return isSignedIn() && request.auth.token.phone_number != null;
    }

    function hasVerifiedContact() {
      return hasVerifiedEmail() || hasVerifiedPhone();
    }

    function keepsEmailVerificationTrusted() {
      return !request.resource.data.keys().hasAny(["emailVerificado"])
        || request.resource.data.emailVerificado == hasVerifiedEmail();
    }

    function keepsPhoneVerificationTrusted() {
      return (
        !request.resource.data.keys().hasAny(["telefoneVerificado"])
        && !request.resource.data.keys().hasAny(["telefoneVerificadoNumero"])
      ) || (
        hasVerifiedPhone()
        && request.resource.data.telefoneVerificado == true
        && request.resource.data.telefoneVerificadoNumero == request.auth.token.phone_number
      ) || (
        !hasVerifiedPhone()
        && request.resource.data.telefoneVerificado == false
        && request.resource.data.telefoneVerificadoNumero == ""
      );
    }

    function keepsVerificationTrusted() {
      return keepsEmailVerificationTrusted() && keepsPhoneVerificationTrusted();
    }

    function keepsOwnRole() {
      return (
        !resource.data.keys().hasAny(["cargo"])
        && request.resource.data.cargo == "cliente"
      ) || (
        resource.data.keys().hasAny(["cargo"])
        && request.resource.data.cargo == resource.data.cargo
      );
    }

    match /usuarios/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.cargo == "cliente"
        && keepsVerificationTrusted();

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && keepsOwnRole()
        && keepsVerificationTrusted()
        && (
          request.resource.data.get("primeiroAcessoCompleto", false) != true
          || hasVerifiedContact()
        )
      );

      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "novo"
        && hasVerifiedContact();

      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isAdmin() || (
        isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.status == "cancelado"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "canceladoEm",
          "atualizadoEm"
        ])
      );

      allow delete: if isAdmin();
    }

    match /parcerias/{parceriaId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "novo"
        && hasVerifiedContact();

      allow read: if isAdmin() || (
        isSignedIn()
        && resource.data.userId == request.auth.uid
      );

      allow update, delete: if isAdmin();
    }

    match /conversas/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid;

      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.userId == resource.data.userId
      );

      allow delete: if isAdmin();

      match /mensagens/{messageId} {
        allow read: if isOwner(userId) || isAdmin();

        allow create: if isSignedIn()
          && (
            (request.auth.uid == userId && request.resource.data.autor == "cliente")
            || (isAdmin() && request.resource.data.autor == "admin")
          );

        allow update, delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
